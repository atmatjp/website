---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import TopLink from "../components/Top-link.astro";
import { ClientRouter } from 'astro:transitions';

import "../styles/style.css";
import "luminous-lightbox/dist/luminous-basic.min.css";

export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="shortcut icon" href="/icon.jpg" type="image/x-icon" />
    <title>{title}</title>

    <ClientRouter />
  </head>
  <body>
    <div class="all">
      <Header pageName={title !== "Home" ? title : null} />
      <slot />
      <TopLink />
      <hr />
      <Footer />
    </div>

    <script>
      import { LuminousGallery } from "luminous-lightbox";

      document.addEventListener("astro:page-load", () => {
        // weblog のパクリ
        const containers = document.querySelectorAll(".all");

        containers.forEach((container) => {
          const luminousElems = Array.from(
            container.querySelectorAll(".luminous")
          ) as HTMLElement[];

          if (luminousElems.length > 0) {
            new LuminousGallery(luminousElems);
          }
        });
      });
    </script>
  </body>
</html>
