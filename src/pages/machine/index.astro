<style>
.table-wrap {
  overflow-x: auto;
  margin-top: 1.5rem;
}
.table {
  width: 100%;
  border-collapse: collapse;
  white-space: nowrap;
  font-size: 0.9rem;
  color: aliceblue;
  background-color: rgba(0, 0, 0, 0.1);
}
.table th,
.table td {
  padding: 1rem 1.2rem;
  text-align: left;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  border-right: 1px solid rgba(255, 255, 255, 0.05);
  min-width: 120px;
}
.table td:nth-child(3) {
  min-width: 180px;
}

.table tr.sold {
  background-color: rgba(255, 255, 255, 0.05);
  color: #666;
}

.table:not(.no-item) th:first-child,
.table:not(.no-item) td:first-child {
  border-right: 2px solid rgba(136, 158, 232, 0.3);
}
.table.no-item th:first-child,
.table.no-item td:first-child {
  border-right: 1px solid rgba(255, 255, 255, 0.05);
}
.table th:last-child,
.table td:last-child {
  border-right: none;
}
.table th {
  color: #889ee8;
  font-weight: bold;
  border-bottom: 2px solid #889ee8;
  background-color: rgba(136, 158, 232, 0.05);
}
.table tr:nth-child(even) {
  background-color: rgba(255, 255, 255, 0.02);
}
.table tr:hover {
  background-color: rgba(136, 158, 232, 0.05);
}
@media (max-width: 480px) {
  .table th,
  .table td {
    padding: 0.5rem;
  }
}
</style>
