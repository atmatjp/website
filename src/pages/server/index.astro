---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Server">
  <a href="https://r2.onji.cc/website/public/mate-05.png" class="luminous">
  <img src="https://r2.onji.cc/website/public/mate-05.png" alt="jitaku" width="auto" />
  </a>
  <p>
   mate mc(USFF)で構成されたk3sクラスターです。ちっちゃくてかわいいですね。
  </p>

  <h2>スペック </h2>
  <table>
    <thead>
      <tr>
        <th>項目</th>
        <th>内容</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>構成</td>
        <td>i5-8500T (3台) / i3-9100T (2台)</td>
      </tr>
      <tr>
        <td>合計コア / スレッド</td>
        <td>26コア / 26スレッド</td>
      </tr>
      <tr>
        <td>合計メモリ (RAM)</td>
        <td>DDR4 SO-DIMM: 40GB</td>
      </tr>
      <tr>
        <td>合計ストレージ</td>
        <td>
          NVMe SSD: 1.2TB<br />
          HDD: 1TB
        </td>
      </tr>
      <tr>
        <td>OS / クラスタ</td>
        <td>Debian / k3s</td>
      </tr>
      <tr>
        <td>用途</td>
        <td>webサーバ , DNSキャッシュサーバ , NAS , Misskey, botなど</td>
      </tr>
    </tbody>
  </table>
<!--
  <p>
    所有マシンの一覧は<a href="/machine/">こちら</a>
  </p>
-->
  <style>
    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 1.5rem;
      font-size: 0.9rem;
      color: aliceblue;
      background-color: rgba(0, 0, 0, 0.1);
    }
    th,
    td {
      padding: 0.8rem;
      text-align: left;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }
    th:first-child,
    td:first-child {
      border-right: 2px solid rgba(136, 158, 232, 0.3);
      width: 35%;
    }
    th {
      color: #889ee8;
      font-weight: bold;
      border-bottom: 2px solid #889ee8;
      background-color: rgba(136, 158, 232, 0.05);
    }
    tr:nth-child(even) {
      background-color: rgba(255, 255, 255, 0.02);
    }
    tr:hover {
      background-color: rgba(136, 158, 232, 0.05);
    }
    @media (max-width: 480px) {
      th,
      td {
        padding: 0.5rem;
      }
    }
  </style>
</Layout>
